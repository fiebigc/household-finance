{
  "name": "household-finance",
  "private": true,
  "license": "MIT",
  "version": "1.1.0",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:desktop": "npm run desktop:build",
    "build:webkit": "tsc -b && vite build --config vite.webkit.config.ts --mode webkit",
    "preview": "vite preview",
    "dev:webkit": "vite --config vite.webkit.config.ts --mode webkit --port 5173 --strictPort",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "icons:build-dollar-svg": "node packaging/gen-comfortaa-dollar-icon.mjs",
    "icons:generate": "tauri icon src-tauri/icons/app-icon.source.svg -o src-tauri/icons",
    "desktop:pkg:mac": "npm run desktop:build && bash packaging/macos/make-installer-pkg.sh",
    "demo:data:build": "node scripts/build-demo-household-snapshot.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.49.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "date-fns": "^4.1.0",
    "i18next": "^26.0.8",
    "lucide-react": "^0.475.0",
    "papaparse": "^5.5.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.6",
    "recharts": "^2.15.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@fontsource/comfortaa": "^5.2.8",
    "@tauri-apps/cli": "^2.11.0",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "opentype.js": "^1.3.5",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tesseract.js": "^6.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.2",
    "wawoff2": "^2.0.1"
  }
}
