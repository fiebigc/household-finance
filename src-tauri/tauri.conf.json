{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal Finances",
  "version": "1.1.0",
  "identifier": "local.finances.household",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:webkit",
    "beforeBuildCommand": "npm run build:webkit"
  },
  "app": {
    "windows": [
      {
        "title": "Personal Finances",
        "width": 1280,
        "height": 840,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
