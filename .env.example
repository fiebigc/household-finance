# Browser (safe to expose in built static assets — use anon / publishable key only)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Optional alias used by src/lib/supabase.ts
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Local seed script only — never commit real values; never prefix with VITE_
SUPABASE_SERVICE_ROLE_KEY=

# UUID from Supabase Dashboard → Authentication → Users (owner of bank CSV rows)
SEED_OWNER_USER_ID=

# Optional comma-separated UUIDs (e.g. partner) who can read the same accounts via RLS.
# Requires migration 20260413120000_bank_account_access.sql applied.
# SEED_BANK_ACCESS_SCOPE=all (default) | joint — joint = only owners containing "joint"
# SEED_BANK_ACCESS_USER_IDS=
