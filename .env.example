# Copy to .env locally. Never commit .env.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: override bundled generic household display names (defaults: Adult 1/2, Child 1/2).
# VITE_ADULT_1_LABEL=
# VITE_ADULT_2_LABEL=
# VITE_CHILD_1_LABEL=
# VITE_CHILD_2_LABEL=
# VITE_TRANSITION_DATE=

# Tink: browser calls YOUR backend; backend holds Tink client secret and creates Link sessions.
# Example: https://finances-api.your-domain.workers.dev/tink
VITE_TINK_CONNECT_API_BASE_URL=

# Optional (most setups keep client id server-side only)
# VITE_TINK_CLIENT_ID=

# Optional: show “demo” hints in the Tink card
# VITE_TINK_DEMO_MODE=false
