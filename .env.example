# Copy to `.env`. Never commit real values (see `.gitignore`).

# Cloud storage (optional). Leave unset to use local folder vault only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Desktop WebKit (Tauri) bundle: omit Supabase from the frontend — see `.env.webkit` and `vite.webkit.config.ts`.
# VITE_WEBKIT_STANDALONE=true

# Optional: override bundled generic household display names (defaults: Adult 1/2, Child 1/2).
# VITE_ADULT_1_LABEL=
# VITE_ADULT_2_LABEL=
# VITE_CHILD_1_LABEL=
# VITE_CHILD_2_LABEL=
# VITE_TRANSITION_DATE=

# Tink: browser calls YOUR backend; backend holds Tink client secret and creates Link sessions.
# Example: https://finances-api.your-domain.workers.dev/tink
VITE_TINK_CONNECT_API_BASE_URL=

# Optional (most setups keep client id server-side only)
# VITE_TINK_CLIENT_ID=

# Optional: show “demo” hints in the Tink card
# VITE_TINK_DEMO_MODE=false

# Optional “Buy me a coffee” in Settings → About (omit for OSS builds).
# VITE_BUY_ME_A_COFFEE_SLUG=
# Or full profile URL (link only; web widget still needs slug).
# VITE_BUY_ME_A_COFFEE_URL=
